{
  "name": "k-game-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:web": "npm --prefix ./apps/web run dev",
    "dev:api": "npm --prefix ./services/api start",
    "build:web": "npm --prefix ./apps/web run build",
    "test:web": "npm --prefix ./apps/web run test",
    "test:api": "npm --prefix ./services/api test",
    "test:lambdas": "npm --prefix ./services/lambdas/prompt-engine test && npm --prefix ./services/lambdas/prompt-hint test && npm --prefix ./services/lambdas/word-judge test && npm --prefix ./services/lambdas/word-reply test",
    "check:api": "npm --prefix ./services/api run check",
    "check:infra": "terraform -chdir=./infra/terraform init -backend=false && terraform -chdir=./infra/terraform validate"
  }
}
