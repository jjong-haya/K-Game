# Primary API base URL.
# Example:
# VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=http://localhost:4000

# Supabase project URL for Google / Apple social login.
VITE_SUPABASE_URL=

# Supabase public anon key.
VITE_SUPABASE_ANON_KEY=

# Optional explicit redirect URL for Supabase OAuth callback.
# Leave blank to use the current origin + /login.
VITE_SUPABASE_REDIRECT_URL=

# Optional legal links shown on the social login card.
VITE_TERMS_URL=
VITE_PRIVACY_POLICY_URL=

# Legacy REACT_APP_* keys are still accepted by the Vite config for backward compatibility.
