# RDS / MySQL connection
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Express server port
PORT=4000

# Allowed frontend origins for CORS.
# Example:
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# App timezone
APP_TIMEZONE=Asia/Seoul

# Server-side admin allowlist.
# Use social-login email addresses and/or internal user IDs.
ADMIN_EMAILS=
ADMIN_USER_IDS=

# Prompt mode Lambda
GAME_LAMBDA_NOVA_FUNCTION_NAME=
GAME_LAMBDA_NOVA_URL=
GAME_LAMBDA_REGION=us-east-1

# Word mode Lambdas
WORD_JUDGE_FUNCTION_NAME=
WORD_JUDGE_URL=
WORD_JUDGE_REGION=us-east-1
WORD_JUDGE_GEMINI_FUNCTION_NAME=
WORD_JUDGE_GEMINI_URL=
WORD_JUDGE_GEMINI_REGION=us-east-1
WORD_REPLY_FUNCTION_NAME=
WORD_REPLY_URL=
WORD_REPLY_REGION=us-east-1
WORD_REPLY_GEMINI_FUNCTION_NAME=
WORD_REPLY_GEMINI_URL=
WORD_REPLY_GEMINI_REGION=us-east-1
WORD_HINT_FUNCTION_NAME=
WORD_HINT_URL=
WORD_HINT_REGION=us-east-1

# Legacy / optional
GAME_LAMBDA_HINT_FUNCTION_NAME=
GAME_LAMBDA_HINT_URL=
GAME_LAMBDA_HINT_REGION=us-east-1
GAME_LAMBDA_GEMINI_FUNCTION_NAME=

# Supabase project URL used to verify Google / Apple social tokens on the server.
SUPABASE_URL=

# Session durations
GUEST_SESSION_HOURS=12
APP_SESSION_DAYS=30
