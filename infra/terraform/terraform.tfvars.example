aws_region          = "ap-northeast-2"
project_name         = "k-game"
environment          = "prod"
frontend_bucket_name  = "k-game-prod-frontend"
custom_domain_name    = ""
vpc_id                = "vpc-xxxxxxxx"
public_subnet_ids     = ["subnet-aaaaaaa", "subnet-bbbbbbb"]
private_subnet_ids    = ["subnet-ccccccc", "subnet-ddddddd"]
ec2_ami_id            = "ami-xxxxxxxx"
ec2_instance_type     = "t3.small"
db_name               = "k_game"
db_username           = "k_game_admin"
db_password           = "change-me"
db_instance_class     = "db.t3.small"
db_allocated_storage  = 20
log_retention_days    = 30
enable_daily_word_lambda = false
enable_daily_word_schedule = false
daily_word_lambda_name = "k-game-prod-daily-word-generate"
daily_word_lambda_s3_bucket = "replace-with-lambda-artifact-bucket"
daily_word_lambda_s3_key = "daily-word-generate/daily-word-generate.zip"
daily_word_lambda_timeout = 30
daily_word_lambda_memory_size = 512
daily_word_bedrock_model_id = "amazon.nova-lite-v1:0"
daily_word_schedule_expression = "cron(0 15 * * ? *)"
